@startuml
title Открытие депозитного счета Версия 2 Диаграмма контейнеров

top to bottom direction

!include ../../Task3/Container/C4_Container.puml

Person(client, "Клиент", "Новый или существующий клиент банка")
Person(callManager, "Менеджер внутреннего кол-центра", "Обрабатывает заявки новых клиентов")
Person(backOffice, "Сотрудник бэк-офиса", "Подтверждает условия депозита и ведет ставки")
Person(branchEmployee, "Сотрудник отделения", "Проводит идентификацию новых клиентов")

System_Ext(Website, "Сайт банка", "Показывает депозитные продукты и позволяет новому клиенту оставить заявку")
System_Ext(InternetBank, "Интернет-банк", "Позволяет существующему клиенту просматривать ставки и подавать заявку на депозит")
System_Ext(CallCenterSystem, "Система внутреннего кол-центра", "Используется менеджерами для обработки заявок и просмотра ставок")
System_Ext(PartnerCallCenter, "Партнерский кол-центр", "Использует файл актуальных ставок")
System_Ext(FileGateway, "Защищенный файловый шлюз", "Канал файлового обмена с партнером")
System_Ext(ABS, "АБС", "Автоматизированная банковская система банка")
System_Ext(SMSGateway, "SMS-шлюз", "Отправляет SMS-коды и SMS-уведомления клиентам")

System_Boundary(DepositMVP, "Система открытия депозитов") {
    Container(DepositService, "Deposit Application Service", ".NET", "Обрабатывает заявки на открытие депозитов и координирует клиентские сценарии")

    Container(NotificationService, "Notification Service", ".NET", "Инициирует отправку SMS-кодов подтверждения и SMS-уведомлений")

    Container(ABSACL, "ABS ACL", ".NET", "Anti-Corruption Layer для изоляции новой депозитной системы от легаси-модели и интерфейсов АБС")

    ContainerQueue(ABSCommandQueue, "ABS Command Queue", "RabbitMQ", "Очередь команд подтверждения заявок при недоступности АБС")

    Container(ABSSyncWorker, "ABS Sync Worker", ".NET Worker", "Фоново читает очередь, выполняет ретраи и дозавершает заявки в АБС после восстановления")

    ContainerDb(DepositDb, "Deposit DB", "MS SQL", "Хранит заявки, статусы обработки, ставки и историю публикации")
}

Rel(client, Website, "Просматривает депозиты и оставляет заявку", "HTTPS")
Rel(client, InternetBank, "Просматривает ставки и подает заявку", "HTTPS")
Rel(callManager, CallCenterSystem, "Обрабатывает заявки и консультирует по ставкам")
Rel(backOffice, ABS, "Подтверждает условия депозита, работает со ставками", "HTTPS / Web")
Rel(branchEmployee, ABS, "Проводит идентификацию и завершает оформление нового клиента")

Rel(Website, DepositService, "Передает заявку нового клиента и запрашивает список депозитов", "HTTPS")
Rel(InternetBank, DepositService, "Передает заявку существующего клиента", "HTTPS")

Rel(CallCenterSystem, DepositService, "Получает данные по заявкам новых клиентов", "HTTPS")
Rel(CallCenterSystem, DepositService, "Запрашивает актуальные ставки (read-only)", "HTTPS")

Rel(DepositService, ABSACL, "Передает команды и запросы для операций по депозиту")
Rel(DepositService, ABSCommandQueue, "Публикует команды при недоступности АБС")
Rel(DepositService, DepositDb, "Сохраняет заявки и статусы", "SQL")
Rel(DepositService, NotificationService, "Инициирует отправку SMS-кодов и уведомлений")

Rel(ABSCommandQueue, ABSSyncWorker, "Передает отложенные команды")
Rel(ABSSyncWorker, ABSACL, "Повторно отправляет команды с retry/backoff")
Rel(ABSSyncWorker, DepositDb, "Обновляет статусы обработки", "SQL")

Rel(DepositService, ABSACL, "Получает исходные данные ставок из АБС")
Rel(DepositService, DepositDb, "Сохраняет и читает снимок актуальных ставок", "SQL")
Rel(DepositService, FileGateway, "Передает файл актуальных ставок", "SFTP")
Rel(FileGateway, PartnerCallCenter, "Доставляет файл актуальных ставок")

Rel(ABSACL, ABS, "Вызывает интерфейсы АБС в адаптированном формате")
Rel(NotificationService, SMSGateway, "Отправляет SMS-коды и уведомления")

@enduml
