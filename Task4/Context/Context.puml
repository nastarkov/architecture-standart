@startuml
title Открытие депозитного счета Версия 2 Диаграмма контекста

top to bottom direction

!include ../../Task3/Context/C4_Context.puml

Person(client, "Клиент", "Новый или существующий клиент банка, подающий заявку на открытие депозита")
Person(callManager, "Менеджер внутреннего кол-центра", "Обрабатывает заявки и консультирует по актуальным ставкам")
Person(backOffice, "Сотрудник бэк-офиса", "Подтверждает условия депозита и работает со ставками")
Person(branchEmployee, "Сотрудник отделения", "Проводит идентификацию новых клиентов в отделении")

System(depositSystem, "Система открытия депозитов", "Центральная система MVP для подачи и обработки заявок, публикации ставок и интеграции с АБС")

System_Ext(site, "Сайт банка", "Показывает депозитные продукты и позволяет новому клиенту оставить заявку")
System_Ext(ib, "Интернет-банк", "Позволяет существующему клиенту просматривать ставки и подавать заявку на депозит")
System_Ext(callCenter, "Система внутреннего кол-центра", "Используется менеджерами для обработки заявок")
System_Ext(partnerCallCenter, "Партнерский кол-центр", "Подхватывает часть обращений при пиковой нагрузке")
System_Ext(fileGateway, "Защищенный файловый шлюз", "Контур передачи файлов ставок партнеру")
System_Ext(abs, "АБС", "Автоматизированная банковская система, в которой подтверждаются условия и учитываются операции")
System_Ext(smsGateway, "SMS-шлюз", "Отправляет SMS-коды подтверждения и SMS-уведомления клиентам")

Rel(client, site, "Просматривает депозиты и оставляет заявку")
Rel(client, ib, "Просматривает ставки и подает заявку на депозит")

Rel(site, depositSystem, "Передает заявку нового клиента")
Rel(ib, depositSystem, "Передает заявку существующего клиента")

Rel(callManager, callCenter, "Обрабатывает заявки")
Rel(callCenter, depositSystem, "Получает заявки и актуальные ставки через API")

Rel(backOffice, depositSystem, "Работает со ставками и подтверждает условия заявки")
Rel(branchEmployee, depositSystem, "Завершает оформление нового клиента после идентификации")

Rel(depositSystem, fileGateway, "Формирует и передает файл актуальных ставок")
Rel(fileGateway, partnerCallCenter, "Доставляет файл актуальных ставок")

Rel(depositSystem, abs, "Передает данные для подтверждения и открытия депозита")
Rel(depositSystem, smsGateway, "Инициирует отправку SMS-кодов и уведомлений")

@enduml
